<?xml version="1.0" encoding="UTF-8"?>
<?mso-application progid="Excel.Sheet"?>
<Workbook xmlns="urn:schemas-microsoft-com:office:spreadsheet"
 xmlns:o="urn:schemas-microsoft-com:office:office"
 xmlns:x="urn:schemas-microsoft-com:office:excel"
 xmlns:ss="urn:schemas-microsoft-com:office:spreadsheet"
 xmlns:html="http://www.w3.org/TR/REC-html40">
<DocumentProperties xmlns="urn:schemas-microsoft-com:office:office">
  <Title>ASPD rocalc vs rAthena</Title>
</DocumentProperties>
<Styles>
  <Style ss:ID="hdr"><Font ss:Bold="1"/><Interior ss:Color="#4472C4" ss:Pattern="Solid"/><Font ss:Color="#FFFFFF" ss:Bold="1"/></Style>
  <Style ss:ID="cat"><Font ss:Bold="1"/><Interior ss:Color="#D9E2F3" ss:Pattern="Solid"/></Style>
  <Style ss:ID="wrap"><Alignment ss:Vertical="Top" ss:WrapText="1"/></Style>
</Styles>
<Worksheet ss:Name="Comparativo">
<Table ss:ExpandedColumnCount="6" ss:ExpandedRowCount="40" x:FullColumns="1" x:FullRows="1">
<Column ss:Width="140"/><Column ss:Width="40"/><Column ss:Width="200"/><Column ss:Width="280"/><Column ss:Width="280"/><Column ss:Width="220"/>
<Row ss:StyleID="hdr">
  <Cell><Data ss:Type="String">Categoria</Data></Cell>
  <Cell><Data ss:Type="String">ID</Data></Cell>
  <Cell><Data ss:Type="String">Tópico</Data></Cell>
  <Cell><Data ss:Type="String">Modelo rocalc / site</Data></Cell>
  <Cell><Data ss:Type="String">Modelo rAthena</Data></Cell>
  <Cell><Data ss:Type="String">Risco / notas</Data></Cell>
</Row>
<Row ss:StyleID="cat"><Cell ss:MergeAcross="5"><Data ss:Type="String">Estrutura da fórmula</Data></Cell></Row>
<Row ss:StyleID="wrap">
  <Cell><Data ss:Type="String">Estrutura da fórmula</Data></Cell>
  <Cell><Data ss:Type="String">1.1</Data></Cell>
  <Cell><Data ss:Type="String">Ordem dos floor</Data></Cell>
  <Cell><Data ss:Type="String">et = floor(J+ce+…); kt = floor((S+E+et)×…)</Data></Cell>
  <Cell><Data ss:Type="String">Um único floor em temp_aspd + fixo×AGI/200 antes de subtrair arma</Data></Cell>
  <Cell><Data ss:Type="String">Arredondamento pode diferir ±1 ASPD em casos limite</Data></Cell>
</Row>
<Row ss:StyleID="wrap">
  <Cell><Data ss:Type="String">Estrutura da fórmula</Data></Cell>
  <Cell><Data ss:Type="String">1.2</Data></Cell>
  <Cell><Data ss:Type="String">Constante 196 vs base S</Data></Cell>
  <Cell><Data ss:Type="String">Base classe+arma (calcBaseAspd / T3)</Data></Cell>
  <Cell><Data ss:Type="String">+196 − min(base arma, 200)</Data></Cell>
  <Cell><Data ss:Type="String">Equivalente se job_aspd.yml = tabela do site</Data></Cell>
</Row>
<Row ss:StyleID="wrap">
  <Cell><Data ss:Type="String">Estrutura da fórmula</Data></Cell>
  <Cell><Data ss:Type="String">1.3</Data></Cell>
  <Cell><Data ss:Type="String">Teto subtração arma</Data></Cell>
  <Cell><Data ss:Type="String">Implícito na tabela do site</Data></Cell>
  <Cell><Data ss:Type="String">min(…, 200) explícito</Data></Cell>
  <Cell><Data ss:Type="String">Diverge se o cap não for o mesmo</Data></Cell>
</Row>
<Row ss:StyleID="wrap">
  <Cell><Data ss:Type="String">Estrutura da fórmula</Data></Cell>
  <Cell><Data ss:Type="String">1.4</Data></Cell>
  <Cell><Data ss:Type="String">decreaseSkillAspdPercent</Data></Cell>
  <Cell><Data ss:Type="String">Multiplica kt: (S+E+et)×(100−dec)%</Data></Cell>
  <Cell><Data ss:Type="String">Montaria/dragão via val no termo ×AGI/200</Data></Cell>
  <Cell><Data ss:Type="String">Pode não bater com o JS em todos os casos</Data></Cell>
</Row>
<Row ss:StyleID="cat"><Cell ss:MergeAcross="5"><Data ss:Type="String">Passos só no rAthena</Data></Cell></Row>
<Row ss:StyleID="wrap">
  <Cell><Data ss:Type="String">Passos só no rAthena</Data></Cell>
  <Cell><Data ss:Type="String">2.1</Data></Cell>
  <Cell><Data ss:Type="String">aspd_rate / 1000</Data></Cell>
  <Cell><Data ss:Type="String">Não aparece no calcAspd do bundle</Data></Cell>
  <Cell><Data ss:Type="String">amotion ×= aspd_rate/1000 antes do (195−kt)×%</Data></Cell>
  <Cell><Data ss:Type="String">Diverge se aspd_rate ≠ 1000</Data></Cell>
</Row>
<Row ss:StyleID="wrap">
  <Cell><Data ss:Type="String">Passos só no rAthena</Data></Cell>
  <Cell><Data ss:Type="String">2.2</Data></Cell>
  <Cell><Data ss:Type="String">bAspd / SP_ASPD</Data></Cell>
  <Cell><Data ss:Type="String">Flat somado no stat (antes do teto 193)</Data></Cell>
  <Cell><Data ss:Type="String">aspd_add após conversão para ms</Data></Cell>
  <Cell><Data ss:Type="String">Escala e fase diferentes</Data></Cell>
</Row>
<Row ss:StyleID="wrap">
  <Cell><Data ss:Type="String">Passos só no rAthena</Data></Cell>
  <Cell><Data ss:Type="String">2.3</Data></Cell>
  <Cell><Data ss:Type="String">status_calc_fix_aspd</Data></Cell>
  <Cell><Data ss:Type="String">(no site: mistura de flat no stat)</Data></Cell>
  <Cell><Data ss:Type="String">Ajusta amotion em ms (FS, Soul Shadow, etc.)</Data></Cell>
  <Cell><Data ss:Type="String">Fase diferente do calcAspd</Data></Cell>
</Row>
<Row ss:StyleID="wrap">
  <Cell><Data ss:Type="String">Passos só no rAthena</Data></Cell>
  <Cell><Data ss:Type="String">2.4</Data></Cell>
  <Cell><Data ss:Type="String">SA_FREECAST</Data></Cell>
  <Cell><Data ss:Type="String">Se o simulador tiver regra equivalente</Data></Cell>
  <Cell><Data ss:Type="String">Multiplica stat ASPD durante cast</Data></Cell>
  <Cell><Data ss:Type="String">Conferir paridade no site</Data></Cell>
</Row>
<Row ss:StyleID="cat"><Cell ss:MergeAcross="5"><Data ss:Type="String">Dados</Data></Cell></Row>
<Row ss:StyleID="wrap">
  <Cell><Data ss:Type="String">Dados</Data></Cell>
  <Cell><Data ss:Type="String">3.1</Data></Cell>
  <Cell><Data ss:Type="String">job_aspd.yml</Data></Cell>
  <Cell><Data ss:Type="String">Tabela interna T3 / calcBaseAspd</Data></Cell>
  <Cell><Data ss:Type="String">db/re/job_aspd.yml</Data></Cell>
  <Cell><Data ss:Type="String">Qualquer diferença altera o número final</Data></Cell>
</Row>
<Row ss:StyleID="wrap">
  <Cell><Data ss:Type="String">Dados</Data></Cell>
  <Cell><Data ss:Type="String">3.2</Data></Cell>
  <Cell><Data ss:Type="String">Itens</Data></Cell>
  <Cell><Data ss:Type="String">DB do simulador / Divine Pride</Data></Cell>
  <Cell><Data ss:Type="String">item_db (e custom)</Data></Cell>
  <Cell><Data ss:Type="String">Divergência por dados</Data></Cell>
</Row>
<Row ss:StyleID="wrap">
  <Cell><Data ss:Type="String">Dados</Data></Cell>
  <Cell><Data ss:Type="String">3.3</Data></Cell>
  <Cell><Data ss:Type="String">Teto ASPD</Data></Cell>
  <Cell><Data ss:Type="String">min(…, 193) no JS</Data></Cell>
  <Cell><Data ss:Type="String">pc_maxaspd + player.conf</Data></Cell>
  <Cell><Data ss:Type="String">Alinhar max_aspd etc.</Data></Cell>
</Row>
<Row ss:StyleID="cat"><Cell ss:MergeAcross="5"><Data ss:Type="String">Fixo vs percentual (conferir tipo no site)</Data></Cell></Row>
<Row ss:StyleID="wrap">
  <Cell><Data ss:Type="String">Fixo vs %</Data></Cell>
  <Cell><Data ss:Type="String">4.0</Data></Cell>
  <Cell><Data ss:Type="String">Swing Dance (patch)</Data></Cell>
  <Cell><Data ss:Type="String">skillAspd + Lesson no ce</Data></Cell>
  <Cell><Data ss:Type="String">4×Lv+WM_LESSON no ramo fixo</Data></Cell>
  <Cell><Data ss:Type="String">Ajustado ao rocalc</Data></Cell>
</Row>
<Row ss:StyleID="wrap">
  <Cell><Data ss:Type="String">Fixo vs %</Data></Cell>
  <Cell><Data ss:Type="String">4.1</Data></Cell>
  <Cell><Data ss:Type="String">Dance With Wug</Data></Cell>
  <Cell><Data ss:Type="String">Verificar skillAspd vs % no bundle</Data></Cell>
  <Cell><Data ss:Type="String">val3 no ramo %</Data></Cell>
  <Cell><Data ss:Type="String">Possível divergência de tipo</Data></Cell>
</Row>
<Row ss:StyleID="wrap">
  <Cell><Data ss:Type="String">Fixo vs %</Data></Cell>
  <Cell><Data ss:Type="String">4.2</Data></Cell>
  <Cell><Data ss:Type="String">Increase AGI</Data></Cell>
  <Cell><Data ss:Type="String">aspd%</Data></Cell>
  <Cell><Data ss:Type="String">SC_INCREASEAGI val1 no %</Data></Cell>
  <Cell><Data ss:Type="String">Conferir valores por nível</Data></Cell>
</Row>
<Row ss:StyleID="wrap">
  <Cell><Data ss:Type="String">Fixo vs %</Data></Cell>
  <Cell><Data ss:Type="String">4.3</Data></Cell>
  <Cell><Data ss:Type="String">Aula Musical (BA)</Data></Cell>
  <Cell><Data ss:Type="String">Lesson do caster (coro)</Data></Cell>
  <Cell><Data ss:Type="String">Nível BA do receptor no %</Data></Cell>
  <Cell><Data ss:Type="String">Semântica diferente</Data></Cell>
</Row>
<Row ss:StyleID="wrap">
  <Cell><Data ss:Type="String">Fixo vs %</Data></Cell>
  <Cell><Data ss:Type="String">4.4–4.8</Data></Cell>
  <Cell><Data ss:Type="String">Plágio / Adrenaline / Assumpt? / Madness / Poções</Data></Cell>
  <Cell><Data ss:Type="String">Conforme tong-calc</Data></Cell>
  <Cell><Data ss:Type="String">Ramos fixo ou % em status_calc_aspd</Data></Cell>
  <Cell><Data ss:Type="String">Conferir cada skill</Data></Cell>
</Row>
<Row ss:StyleID="wrap">
  <Cell><Data ss:Type="String">Fixo vs %</Data></Cell>
  <Cell><Data ss:Type="String">4.9+</Data></Cell>
  <Cell><Data ss:Type="String">Debuffs (DFM, Steel Body, Freezing…)</Data></Cell>
  <Cell><Data ss:Type="String">aspd% negativo no site</Data></Cell>
  <Cell><Data ss:Type="String">Ramo % (status_calc_aspd false)</Data></Cell>
  <Cell><Data ss:Type="String">Conferir valores</Data></Cell>
</Row>
<Row ss:StyleID="wrap">
  <Cell><Data ss:Type="String">Fixo vs %</Data></Cell>
  <Cell><Data ss:Type="String">4.14+</Data></Cell>
  <Cell><Data ss:Type="String">Buffs (GT, Ferse, Gatling, Star…)</Data></Cell>
  <Cell><Data ss:Type="String">Fixo ou % no bundle</Data></Cell>
  <Cell><Data ss:Type="String">Maioria no ramo %</Data></Cell>
  <Cell><Data ss:Type="String">Validar tipo no JS</Data></Cell>
</Row>
<Row ss:StyleID="cat"><Cell ss:MergeAcross="5"><Data ss:Type="String">Fora do calcAspd</Data></Cell></Row>
<Row ss:StyleID="wrap">
  <Cell><Data ss:Type="String">Fora calcAspd</Data></Cell>
  <Cell><Data ss:Type="String">5.1–5.3</Data></Cell>
  <Cell><Data ss:Type="String">FCT/VCT, delay de skill, traits</Data></Cell>
  <Cell><Data ss:Type="String">Outros pipelines no simulador</Data></Cell>
  <Cell><Data ss:Type="String">skill.cpp / outros módulos</Data></Cell>
  <Cell><Data ss:Type="String">Não é o mesmo ASPD de ataque</Data></Cell>
</Row>
</Table>
